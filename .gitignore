# =========================
# Terraform files
# =========================

# Local .terraform directories
.terraform/

# Terraform state files (VERY IMPORTANT - never commit)
*.tfstate
*.tfstate.*

# Terraform lock file
.terraform.lock.hcl

# Crash logs
crash.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# =========================
# Terraform plan output
# =========================
*.tfplan

# =========================
# Lock file (OPTIONAL)
# =========================
# Usually you SHOULD commit this for team consistency
# Uncomment if you want to ignore
# .terraform.lock.hcl

# =========================
# Environment files
# =========================
.env
.env.*

# =========================
# OS / Editor files
# =========================
.DS_Store
Thumbs.db

# VS Code
.vscode/

# IntelliJ / JetBrains
.idea/

# =========================
# Logs
# =========================
*.log